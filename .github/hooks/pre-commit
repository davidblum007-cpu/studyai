#!/bin/sh
# Pre-commit hook: Block commits containing secrets
# Install: cp .github/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Patterns that must never be committed
PATTERNS=(
  "sk-ant-api"
  "BEGIN RSA PRIVATE KEY"
  "BEGIN PRIVATE KEY"
  "firebase_credentials"
  "\"private_key\":"
)

BLOCKED=0
for pattern in "${PATTERNS[@]}"; do
  # Search staged files (exclude config/example/docs files to avoid false positives)
  MATCHES=$(git diff --cached --name-only | \
    grep -v ".env.example" | \
    grep -v "\.md$" | \
    grep -v "\.toml$" | \
    grep -v "docker-compose\.yml$" | \
    xargs grep -l "$pattern" 2>/dev/null)
  if [ -n "$MATCHES" ]; then
    echo "${RED}🚫 SECRET DETECTED in staged files: $pattern${NC}"
    echo "   Files: $MATCHES"
    BLOCKED=1
  fi
done

# Block .env and credentials files from being committed
BLOCKED_FILES=$(git diff --cached --name-only | grep -E "^\.env$|firebase_credentials|adminsdk.*\.json$")
if [ -n "$BLOCKED_FILES" ]; then
  echo "${RED}🚫 BLOCKED: Sensitive file staged for commit:${NC}"
  echo "   $BLOCKED_FILES"
  BLOCKED=1
fi

if [ "$BLOCKED" -eq 1 ]; then
  echo ""
  echo "${YELLOW}⚠️  Commit aborted. Remove secrets before committing.${NC}"
  echo "   If this is a false positive, use: git commit --no-verify"
  exit 1
fi

exit 0
