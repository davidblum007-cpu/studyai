# ──────────────────────────────────────────────────────
#  StudyAI – Umgebungsvariablen
#  Kopiere diese Datei als ".env" und trage deine Werte ein.
# ──────────────────────────────────────────────────────

# Anthropic Claude API Key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-DEIN_KEY_HIER

# Flask-Konfiguration
FLASK_SECRET_KEY=ersetze_mich_mit_einem_zufaelligen_string
FLASK_ENV=development
FLASK_PORT=5000

# Analyse-Einstellungen
CHUNK_SIZE_WORDS=2000
MAX_PDF_SIZE_MB=20
MAX_PAGES=200
CLAUDE_MODEL=claude-sonnet-4-6

# CORS: Erlaubte Origins (kommagetrennt, kein Leerzeichen)
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# SQLite Datenbankpfad (Standard: studyai.db im Projektordner)
# STUDYAI_DB=studyai.db

# Firebase Firestore Cloud-Sync + Admin SDK (optional)
# 1. Firebase-Projekt: https://console.firebase.google.com
# 2. Project Settings → Service Accounts → "Generate new private key"
# 3. JSON speichern und Pfad hier eintragen
# FIREBASE_CREDENTIALS_PATH=C:/pfad/zu/serviceAccountKey.json
# FIREBASE_PROJECT_ID=dein-firebase-projekt-id

# Firebase Authentication (Phase 2)
# Notwendig für Login-Funktion (Google OAuth, Email/Passwort)
# Werte findest du unter: Firebase Console → Project Settings → General → "Your apps"
# Falls noch keine Web-App registriert: auf "</>" klicken → Web-App hinzufügen
#
# FIREBASE_WEB_API_KEY=AIzaSy...           ← "apiKey" aus dem SDK-Config-Snippet
# FIREBASE_AUTH_DOMAIN=mein-projekt.firebaseapp.com
# FIREBASE_STORAGE_BUCKET=mein-projekt.appspot.com
# FIREBASE_MESSAGING_SENDER_ID=123456789
# FIREBASE_APP_ID=1:123456789:web:abc123
#
# Außerdem in der Firebase Console aktivieren:
#   Authentication → Sign-in method → Google → aktivieren
#   Authentication → Sign-in method → Email/Passwort → aktivieren
#
# Wenn diese Variablen NICHT gesetzt sind, läuft die App im lokalen Modus (kein Login).

# ── Stripe Billing (Phase 2 – Monetarisierung) ──────────────────────────────
# Benötigt für Abo-Funktionen (Pro-Plan, Checkout, Kundenportal)
# 1. https://dashboard.stripe.com → API Keys → Secret Key kopieren
# 2. Produkt erstellen: Products → Add Product → Recurring (€9,99/Monat)
# 3. Webhook: Webhooks → Add endpoint:
#    URL: https://deine-domain.de/api/webhooks/stripe
#    Events: customer.subscription.* und invoice.payment_*
#
# STRIPE_SECRET_KEY=sk_live_...     ← Live-Key für Produktion
# STRIPE_SECRET_KEY=sk_test_...     ← Test-Key für Entwicklung
# STRIPE_PRICE_PRO_MONTHLY=price_...  ← Preis-ID aus Stripe Dashboard
# STRIPE_WEBHOOK_SECRET=whsec_...   ← Webhook Signing Secret
