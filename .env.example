# ══════════════════════════════════════════════════════════════════════════════
#  StudyAI – Umgebungsvariablen (vollständige Referenz)
#  Kopiere diese Datei als ".env" und trage deine Werte ein.
#  NIEMALS ".env" committen – sie steht bereits in .gitignore!
# ══════════════════════════════════════════════════════════════════════════════

# ── PFLICHT ─────────────────────────────────────────────────────────────────
#  Die App startet NICHT ohne diesen Key.
#
#  Woher:  https://console.anthropic.com → API Keys → "Create Key"
#  Format: sk-ant-api03-xxxxx...
#  Kosten: Wird pro Token abgerechnet (~$0.003/1K Input, ~$0.015/1K Output)
#          mit claude-sonnet. Für Tests: claude-haiku (10x günstiger).
ANTHROPIC_API_KEY=sk-ant-DEIN_KEY_HIER


# ── FLASK ────────────────────────────────────────────────────────────────────
#
#  FLASK_SECRET_KEY
#  Für sichere Sessions, CSRF-Schutz und JWT-Signing.
#  Generieren: python -c "import secrets; print(secrets.token_hex(32))"
#  WICHTIG: Bei leerem Wert generiert die App einen temporären Key →
#           alle User werden bei jedem Server-Neustart ausgeloggt!
#  Für Produktion zwingend erforderlich.
FLASK_SECRET_KEY=ersetze_mich_mit_einem_zufaelligen_string

#  FLASK_ENV
#  "development" → Debug-Modus, Auto-Reload, Fehlermeldungen sichtbar
#  "production"  → Kein Debug, kein Auto-Reload, sichere Fehlerbehandlung
#  Für öffentlichen Server IMMER "production" verwenden!
FLASK_ENV=development

#  FLASK_PORT
#  Port auf dem der Server lauscht.
#  Lokal: 5000 üblich. Für Produktion: 8080 oder per Reverse-Proxy auf 443.
FLASK_PORT=5000

#  FLASK_HOST
#  "127.0.0.1" = nur lokal erreichbar (sicher für Entwicklung)
#  "0.0.0.0"   = von außen erreichbar (für Server / Docker)
# FLASK_HOST=127.0.0.1


# ── ANALYSE-EINSTELLUNGEN ────────────────────────────────────────────────────
#  Alle haben sinnvolle Standardwerte – nur bei Bedarf anpassen.
#
#  CHUNK_SIZE_WORDS: Wörter pro Analyse-Chunk.
#    Kleiner = schnellere API-Calls, weniger Kontext pro Chunk.
#    Größer  = mehr Kontext, langsamere Calls, evtl. teurere Tokens.
#    Standard: 2000 (guter Kompromiss)
CHUNK_SIZE_WORDS=2000

#  MAX_PDF_SIZE_MB: Maximale Upload-Größe einer einzelnen PDF in Megabyte.
MAX_PDF_SIZE_MB=20

#  MAX_PAGES: Maximale Seitenanzahl pro PDF.
MAX_PAGES=200

#  CLAUDE_MODEL: Welches KI-Modell verwendet wird.
#    claude-sonnet-4-6   → Beste Qualität, Standard (empfohlen)
#    claude-haiku-4-5    → 10x günstiger, etwas schlechtere Qualität
#    claude-opus-4-5     → Beste Qualität, 5x teurer als Sonnet
CLAUDE_MODEL=claude-sonnet-4-6

#  ALLOWED_ORIGINS: CORS – welche Frontend-Origins dürfen API aufrufen.
#  Kommagetrennt, kein Leerzeichen zwischen den Einträgen.
#  Für Produktion: nur deine echte Domain eintragen!
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

#  STUDYAI_DB: Pfad zur SQLite-Datenbankdatei.
#  Standard: studyai.db im aktuellen Verzeichnis.
# STUDYAI_DB=studyai.db

#  ML_MODELS_DIR: Verzeichnis für per-User ML-Spaced-Repetition-Modelle.
#  Jeder User bekommt eine eigene .pkl-Datei (sr_model_<uid>.pkl).
#  Standard: ml_models/ im Projektverzeichnis.
# ML_MODELS_DIR=ml_models

#  ADMIN_UIDS: Kommagetrennte Firebase-UIDs der Admin-User.
#  Gibt Zugriff auf GET /api/admin/stats (Kosten, User-Anzahl, etc.).
#  Deine UID findest du im Firebase Console → Authentication → Users → UID-Spalte.
#  Leer lassen = Admin-Dashboard nur von localhost erreichbar.
# ADMIN_UIDS=uid1,uid2


# ── FIREBASE (für Login & Cloud-Sync) ────────────────────────────────────────
#  Ohne Firebase: App läuft im lokalen Modus ohne Login.
#  Mit Firebase:  Google OAuth + Email/Passwort Login, Cloud-Synchronisation.
#
#  SETUP (einmalig):
#  1. https://console.firebase.google.com → Projekt erstellen (oder öffnen)
#  2. Authentication → Sign-in method → Google → aktivieren
#  3. Authentication → Sign-in method → Email/Passwort → aktivieren
#
#  FÜR DEN SERVER (Admin SDK):
#  4. Project Settings → Service Accounts → "Generate new private key"
#  5. JSON-Datei sicher speichern (NICHT committen!)
#  6. Pfad in FIREBASE_CREDENTIALS_PATH eintragen
#
#  FÜR DAS FRONTEND (Web Config):
#  7. Project Settings → General → "Your apps" → Web-App (</>)
#     Falls keine Web-App: auf "</>" klicken → Web-App registrieren
#  8. SDK-Config-Snippet anzeigen → Werte unten eintragen

# Server-seitige Admin-Credentials (für Token-Verifikation + Firestore-Sync)
# FIREBASE_CREDENTIALS_PATH=C:/pfad/zu/firebase_credentials.json
# FIREBASE_PROJECT_ID=studyai-f3063

# Frontend-Config (wird an den Browser gesendet – diese Werte sind öffentlich sicher)
# FIREBASE_WEB_API_KEY=AIzaSy...
# FIREBASE_AUTH_DOMAIN=studyai-f3063.firebaseapp.com
# FIREBASE_STORAGE_BUCKET=studyai-f3063.appspot.com
# FIREBASE_MESSAGING_SENDER_ID=123456789
# FIREBASE_APP_ID=1:123456789:web:abc123


# ── STRIPE BILLING (für Paid Subscriptions) ──────────────────────────────────
#  Ohne Stripe: Free-Tier funktioniert, Upgrade-Button erscheint,
#               aber Checkout schlägt fehl ("Stripe nicht konfiguriert").
#  Mit Stripe:  Pro-Abo für €9,99/Monat, Kundenverwaltung, Webhooks.
#
#  SETUP (einmalig):
#  1. https://dashboard.stripe.com → Account erstellen
#  2. Developers → API Keys → Secret Key kopieren
#     → Für Entwicklung: "sk_test_..." Key verwenden (kein echtes Geld)
#     → Für Produktion:  "sk_live_..." Key verwenden
#
#  3. Produkt erstellen:
#     Products → "Add Product" → Name: "StudyAI Pro"
#     Preis: €9,99 → Recurring → Monthly → Speichern
#     → Preis-ID ("price_1ABC...") notieren für STRIPE_PRICE_PRO_MONTHLY
#
#  4. Webhook einrichten (NUR für Produktion nötig):
#     Developers → Webhooks → "Add endpoint"
#     URL: https://deine-domain.de/api/webhooks/stripe
#     Events aktivieren:
#       ✓ customer.subscription.created
#       ✓ customer.subscription.updated
#       ✓ customer.subscription.deleted
#       ✓ invoice.payment_succeeded
#       ✓ invoice.payment_failed
#     → Signing Secret ("whsec_...") für STRIPE_WEBHOOK_SECRET kopieren
#
#  STRIPE_SECRET_KEY: Secret Key aus Stripe Dashboard (Developers → API Keys)
# STRIPE_SECRET_KEY=sk_test_51...

#  STRIPE_PRICE_PRO_MONTHLY: Preis-ID des monatlichen Pro-Abos
#  Format: price_1xxxxxxxxxxxxxxxxx
# STRIPE_PRICE_PRO_MONTHLY=price_...

#  STRIPE_WEBHOOK_SECRET: Signing Secret für Webhook-Signaturprüfung
#  Verhindert gefälschte Webhook-Anfragen. Erst nach Webhook-Einrichtung nötig.
# STRIPE_WEBHOOK_SECRET=whsec_...


# ── PRODUKTIONS-INFRASTRUKTUR (Phase 3) ──────────────────────────────────────
#
#  REDIS_URL: Redis-Verbindung für Rate-Limiting + Health-Check.
#  Im Docker-Stack (docker-compose.yml) automatisch auf redis://redis:6379/0.
#  Ohne Redis läuft Rate-Limiting im In-Memory-Modus (kein Clustering!).
# REDIS_URL=redis://redis:6379/0

#  SENTRY_DSN: Fehler-Tracking via Sentry.io.
#  Kostenloser Free-Plan ausreichend für Start.
#  Setup: https://sentry.io → Neues Projekt (Python) → DSN kopieren.
#  Wenn leer: Sentry deaktiviert, kein Fehler.
# SENTRY_DSN=https://xxx@o123456.ingest.sentry.io/789

#  SENTRY_TRACES_RATE: Sampling-Rate für Performance-Monitoring (0.0–1.0).
#  0.05 = 5% der Requests getrackt. In Produktion empfohlen.
# SENTRY_TRACES_RATE=0.05

#  APP_VERSION: Version für Sentry-Releases und /api/health Endpoint.
# APP_VERSION=1.0.0


# ══════════════════════════════════════════════════════════════════════════════
#  SCHNELLSTART-PROFILE
# ══════════════════════════════════════════════════════════════════════════════
#
#  ── Minimal (lokal, kein Login) ──────────────────────────────────────────────
#  ANTHROPIC_API_KEY=sk-ant-api03-...
#  FLASK_SECRET_KEY=<zufällig generiert>
#  FLASK_ENV=development
#  FLASK_PORT=5000
#
#  ── Vollständig (Produktion mit Login + Billing) ──────────────────────────────
#  ANTHROPIC_API_KEY=sk-ant-api03-...
#  FLASK_SECRET_KEY=<64-char zufälliger string>
#  FLASK_ENV=production
#  FLASK_PORT=8080
#  FLASK_HOST=0.0.0.0
#  FIREBASE_CREDENTIALS_PATH=/app/firebase_credentials.json
#  FIREBASE_PROJECT_ID=studyai-f3063
#  FIREBASE_WEB_API_KEY=AIzaSy...
#  FIREBASE_AUTH_DOMAIN=studyai-f3063.firebaseapp.com
#  FIREBASE_STORAGE_BUCKET=studyai-f3063.appspot.com
#  FIREBASE_MESSAGING_SENDER_ID=...
#  FIREBASE_APP_ID=1:...:web:...
#  STRIPE_SECRET_KEY=sk_live_...
#  STRIPE_PRICE_PRO_MONTHLY=price_...
#  STRIPE_WEBHOOK_SECRET=whsec_...
